{
  "version": 2,
  "builds": [
    { "src": "api/inbox.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/inbox", "dest": "/api/inbox.js" },
    { "src": "/sw.js", "dest": "/public/sw.js" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
